  "id": "ALAS2-2026-3284",
  "title": "Amazon Linux 2 2017.12 - ALAS2-2026-3284: important priority package update for ruby",
  "issued": {
    "date": "2026-05-11 09:00:00"
  },
  "updated": {
    "date": "2026-05-13 19:55:00"
