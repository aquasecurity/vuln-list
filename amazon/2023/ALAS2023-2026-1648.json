  "id": "ALAS2023-2026-1648",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1648: Important priority package update for nodejs22",
  "issued": {
    "date": "2026-05-11 09:00:00"
  },
  "updated": {
    "date": "2026-05-11 09:00:00"
