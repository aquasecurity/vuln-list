  "id": "ALAS2023-2026-1870",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1870: Important priority package update for clamav1.5",
  "issued": {
    "date": "2026-06-22 09:00:00"
  },
  "updated": {
    "date": "2026-06-22 11:56:00"
