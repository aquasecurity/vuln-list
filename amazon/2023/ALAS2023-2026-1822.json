  "id": "ALAS2023-2026-1822",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1822: Important priority package update for freerdp",
  "issued": {
    "date": "2026-06-08 09:00:00"
  },
  "updated": {
    "date": "2026-06-22 11:56:00"
