  "id": "ALAS2023-2026-1570",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1570: Important priority package update for dovecot",
  "issued": {
    "date": "2026-04-13 09:00:00"
  },
  "updated": {
    "date": "2026-04-13 14:55:00"
