  "id": "ALAS2023-2026-1773",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1773: Important priority package update for nginx",
  "issued": {
    "date": "2026-06-08 09:00:00"
  },
  "updated": {
    "date": "2026-06-08 09:00:00"
