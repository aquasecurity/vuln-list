  "id": "ALAS2023-2026-1550",
  "title": "Amazon Linux 2023 - ALAS2023-2026-1550: Medium priority package update for ImageMagick",
  "issued": {
    "date": "2026-04-13 09:00:00"
  },
  "updated": {
    "date": "2026-04-13 09:00:00"
