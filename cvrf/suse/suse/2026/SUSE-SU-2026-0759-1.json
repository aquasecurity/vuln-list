  "Notes": [
    {
      "Text": "Security update for busybox",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for busybox fixes the following issues:\n\n- CVE-2026-26157: Arbitrary file overwrite and potential code execution via incomplete path sanitization (bsc#1258163).\n- CVE-2026-26158: Arbitrary file modification and privilege escalation via unvalidated tar archive entries\n  (bsc#1258167).\n",
      "Title": "Details",
      "Type": "General"
    },
