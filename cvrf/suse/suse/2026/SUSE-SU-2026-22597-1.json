          "Type": "Fixed",
          "ProductID": [
            "SUSE Linux Micro 6.2:jq-1.7.1-160000.4.1",
            "SUSE Linux Micro 6.2:libjq1-1.7.1-160000.4.1"
          ]
        }
      ],
      "CVSSScoreSets": {}
    },
