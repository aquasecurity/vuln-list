  "Notes": [
    {
      "Text": "Security update for libvirt",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for libvirt fixes the following issues:\n\n- CVE-2025-12748: Denial of service in XML parsing (bsc#1253278).\n- CVE-2025-13193: Information disclosure via world-readable VM snapshots (bsc#1253703).\n",
      "Title": "Details",
      "Type": "General"
    },
