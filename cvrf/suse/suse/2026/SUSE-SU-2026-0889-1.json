  "Vulnerabilities": [
    {
      "CVE": "CVE-2025-14876",
      "Description": "A flaw was found in the virtio-crypto device of QEMU. A malicious guest operating system can exploit a missing length limit in the AKCIPHER path, leading to uncontrolled memory allocation. This can result in a denial of service (DoS) on the host system by causing the QEMU process to terminate unexpectedly.",
      "Threats": [
        {
          "Type": "Impact",
          "Severity": "moderate"
        }
