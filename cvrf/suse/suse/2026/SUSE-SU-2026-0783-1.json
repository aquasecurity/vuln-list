  "Notes": [
    {
      "Text": "Security update for zlib",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for zlib fixes the following issue:\n\n- CVE-2026-27171: Fixed infinite loop via the `crc32_combine64` and `crc32_combine_gen64` functions due to missing\n  checks for negative lengths (bsc#1258392).\n",
      "Title": "Details",
      "Type": "General"
    },
