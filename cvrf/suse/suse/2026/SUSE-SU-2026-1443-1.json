  "Notes": [
    {
      "Text": "Security update for NetworkManager",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for NetworkManager fixes the following issue:\n\nSecurity fixes:\n\n- CVE-2025-9615: Fixed non-admin user using others' certificates (bsc#1257359).\n\nOther fixes:\n\n- Don't renew DHCP lease when software devices' MAC is empty (bsc#1225498).\n",
      "Title": "Details",
      "Type": "General"
    },
