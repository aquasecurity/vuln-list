  "Notes": [
    {
      "Text": "Security update for qemu",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for qemu fixes the following issues:\n\n- CVE-2025-14876: Fixed unbounded allocation in virtio-crypto. (bsc#1255400)\n- CVE-2026-0665: Fixed PIRQ bounds check in xen_physdev_map_pirq. (bsc#1256484)\n",
      "Title": "Details",
      "Type": "General"
    },
