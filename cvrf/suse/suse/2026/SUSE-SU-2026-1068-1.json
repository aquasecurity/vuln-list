  "Notes": [
    {
      "Text": "Security update for pgvector",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for pgvector fixes the following issue:\n\nUpdate to pgvector 0.8.2:\n\n- CVE-2026-3172: Buffer overflow in parallel HNSW index build (bsc#1258945).\n\nChangelog:\n\n * Fixed Index Searches in EXPLAIN output for Postgres 18\n",
      "Title": "Details",
      "Type": "General"
    },
