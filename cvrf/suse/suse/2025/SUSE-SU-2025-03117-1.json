  "Notes": [
    {
      "Text": "Security update for regionServiceClientConfigAzure",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for regionServiceClientConfigAzure contains the following fixes:\n\n- Update to version 3.0.0.(bsc#1246995)\n  + SLE 16 python-requests requires SSL v3 certificates. Update 2\n    region server certs to support SLE 16 when it gets released.\n\n- Update dependency name for metadata package, name change in\n  SLE 16. (bsc#1243419)\n\n  + Replacing certificate for rgnsrv-azure-southeastasia to get\n    rid of weird chain cert\n  ",
      "Title": "Details",
      "Type": "General"
    },
    {
      "Text": "The CVRF data is provided by SUSE under the Creative Commons License 4.0 with Attribution (CC-BY-4.0).",
      "Title": "Terms of Use",
      "Type": "Legal Disclaimer"
    },
