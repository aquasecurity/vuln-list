  "Notes": [
    {
      "Text": "Security update for python",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for python fixes the following issues:\n\n- bsc#1177211 (CVE-2020-26116) no longer allowing special characters in the method parameter \n  of HTTPConnection.putrequest in httplib, stopping injection of headers.\n",
      "Title": "Details",
      "Type": "General"
    },
