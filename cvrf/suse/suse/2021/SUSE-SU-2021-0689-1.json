  "Notes": [
    {
      "Text": "Security update for bind",
      "Title": "Topic",
      "Type": "Summary"
    },
    {
      "Text": "This update for bind fixes the following issues:\n\n- dnssec-keygen can no longer generate HMAC keys. Use tsig-keygen instead. [bsc#1180933]\n",
      "Title": "Details",
      "Type": "General"
